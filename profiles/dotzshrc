#region Self-Update
__dollarsign_autoupdate() {
    [[ -o interactive ]] || return 0
    bash <(curl -fsSL --connect-timeout 3 'https://raw.githubusercontent.com/jakehildreth/profile/refs/heads/main/installers/install.sh' 2>/dev/null)
}
__dollarsign_autoupdate
unset -f __dollarsign_autoupdate
#endregion Self-Update

# UTF-8 encoding
export LANG='en_US.UTF-8'
export LC_ALL='en_US.UTF-8'

# zsh-autosuggestions — source from first known install location
for __zas_path in \
    "$(brew --prefix 2>/dev/null)/share/zsh-autosuggestions/zsh-autosuggestions.zsh" \
    '/usr/share/zsh-autosuggestions/zsh-autosuggestions.zsh' \
    '/usr/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh'; do
    [[ -f "$__zas_path" ]] && { source "$__zas_path"; break; }
done
unset __zas_path

# zsh-syntax-highlighting — must be sourced last among plugins
for __zsh_path in \
    "$(brew --prefix 2>/dev/null)/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh" \
    '/usr/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh' \
    '/usr/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh'; do
    [[ -f "$__zsh_path" ]] && { source "$__zsh_path"; break; }
done
unset __zsh_path

# Keybindings
bindkey '^U'      backward-kill-line      # Ctrl+U        — clear to start of line
bindkey '^[^['    kill-whole-line         # Escape Escape — clear line (safe; avoids breaking alt sequences)
bindkey '\e[1;3D' backward-word           # Alt+Left
bindkey '\e[1;3C' forward-word            # Alt+Right
bindkey '\e[1;5D' backward-word           # Ctrl+Left
bindkey '\e[1;5C' forward-word            # Ctrl+Right
bindkey '^[\177'  backward-kill-word      # Alt+Backspace
bindkey '^H'      backward-kill-word      # Ctrl+Backspace
bindkey '^[[3;5~' kill-word               # Ctrl+Delete
bindkey '^[[3;3~' kill-word               # Alt+Delete

# calver — print current CalVer timestamp (yyyy.M.dHHmm)
calver() {
    local y m d hm
    y="$(date +%Y)"
    m="$(date +%m)"
    d="$(date +%d)"
    hm="$(date +%H%M)"
    printf '%s.%s.%s%s\n' "$y" "${m#0}" "${d#0}" "$hm"
}

# new_credential — interactive credential prompt
# Result stored in __CREDENTIAL_USER and __CREDENTIAL_PASS
new_credential() {
    printf '\nZsh credential request\nEnter your credentials.\n\n'
    local user pass
    read -r "user?User: "
    read -rs "pass?Password for user ${user}: "
    printf '\n'
    export __CREDENTIAL_USER="$user"
    export __CREDENTIAL_PASS="$pass"
}

# Custom prompt — rebuilt before each prompt via precmd hook
autoload -Uz add-zsh-hook
__dollarsign_precmd() {
    local git_branch
    git_branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null)"
    local path_display="${PWD/#$HOME/~}"
    local branch_str=''
    [[ -n "$git_branch" ]] && branch_str=" [${git_branch}]"
    local gt=''
    local shlvl_depth=$SHLVL
    [[ -o login ]] && (( shlvl_depth > 1 )) && (( shlvl_depth-- ))
    local i
    for ((i = 0; i < shlvl_depth; i++)); do gt+='>'; done
    PROMPT=$'\n'"[${COLUMNS}"$'\xc3\x97'"${LINES}] ${path_display}${branch_str}"$'\n'"zsh${gt} "
}
add-zsh-hook precmd __dollarsign_precmd

# get_ip_address — cross-platform IP address retrieval
get_ip_address() {
    if [[ "$(uname -s)" == 'Darwin' ]]; then
        local i ip
        for i in ${(s: :)"$(ifconfig -l)"}; do
            [[ "$i" == 'lo0' ]] && continue
            ip="$(ifconfig "$i" 2>/dev/null | awk '/inet [1-9]/{print $2; exit}')"
            [[ -n "$ip" ]] && printf '%s: %s\n' "$i" "$ip"
        done
    elif command -v ip &>/dev/null; then
        ip addr show | awk '
            /^[0-9]+: / {
                split($2, a, "@")
                iface = a[1]
                sub(/:$/, "", iface)
            }
            /inet [1-9]/ && iface != "lo" {
                addr = $2
                sub(/\/.*/, "", addr)
                print iface ": " addr
            }
        '
    else
        printf '[!] No IP address retrieval method found.\n' >&2
    fi
}

# gai — copy AI instruction URLs to clipboard
# flags: -p personal, -w powershell, -t pester (default: all)
gai() {
    local usePersonal=false
    local usePowerShell=false
    local usePester=false

    local OPTIND opt
    while getopts ':pwt' opt; do
        case "$opt" in
            p) usePersonal=true ;;
            w) usePowerShell=true ;;
            t) usePester=true ;;
            *) ;;
        esac
    done

    if [[ "$usePersonal" == false && "$usePowerShell" == false && "$usePester" == false ]]; then
        usePersonal=true
        usePowerShell=true
        usePester=true
    fi

    local instructions=''

    if [[ "$usePersonal" == true ]]; then
        instructions+='Please read and follow my personal instructions:
https://raw.githubusercontent.com/jakehildreth/jakehildreth/refs/heads/main/.github/copilot-instructions.md
'
    fi

    if [[ "$usePowerShell" == true ]]; then
        instructions+='then read and follow PowerShell best practices:
https://raw.githubusercontent.com/github/awesome-copilot/refs/heads/main/instructions/powershell.instructions.md
'
    fi

    if [[ "$usePester" == true ]]; then
        instructions+='then read and follow Pester testing best practices:
https://raw.githubusercontent.com/github/awesome-copilot/refs/heads/main/instructions/powershell-pester-5.instructions.md'
    fi

    if [[ "$(uname -s)" == 'Darwin' ]]; then
        printf '%s' "$instructions" | pbcopy
    elif command -v xclip &>/dev/null; then
        printf '%s' "$instructions" | xclip -selection clipboard
    elif command -v xsel &>/dev/null; then
        printf '%s' "$instructions" | xsel --clipboard --input
    else
        printf '[!] No clipboard tool found. Copy the following manually:\n\n%s\n' "$instructions"
    fi
}

# dcc — copy conventional commit workflow prompt to clipboard
dcc() {
    local prompt='Compare the current state of this project against its most recent commit.
Using the diff, draft a conventional commit following my standards, then present it to me for approval.
If I approve it, commit, push, and ask me if I want to do a PR.
If yes, draft a pull request title and description.
Return the title and description as separate copy-pastable blocks.'
    if [[ "$(uname -s)" == 'Darwin' ]]; then
        printf '%s' "$prompt" | pbcopy
    elif command -v xclip &>/dev/null; then
        printf '%s' "$prompt" | xclip -selection clipboard
    elif command -v xsel &>/dev/null; then
        printf '%s' "$prompt" | xsel --clipboard --input
    else
        printf '[!] No clipboard tool found. Copy the following manually:\n\n%s\n' "$prompt"
    fi
}

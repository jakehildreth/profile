# UTF-8 encoding
export LANG='en_US.UTF-8'
export LC_ALL='en_US.UTF-8'

# Keybindings — interactive shells only
if [[ $- == *i* ]]; then
    bind '"\C-u": backward-kill-line'       # Ctrl+U        — clear to start of line
    bind '"\C-[": revert-line'              # Escape        — revert line (macOS)
    bind '"\e[1;3D": backward-word'         # Alt+Left
    bind '"\e[1;3C": forward-word'          # Alt+Right
    bind '"\e[1;5D": backward-word'         # Ctrl+Left
    bind '"\e[1;5C": forward-word'          # Ctrl+Right
    bind '"\e\177": backward-kill-word'     # Alt+Backspace
    bind '"\C-_": backward-kill-word'       # Ctrl+Backspace (terminal-dependent)
    bind '"\e[3;5~": kill-word'             # Ctrl+Delete
    bind '"\e[3;3~": kill-word'             # Alt+Delete
fi

# calver — print current CalVer timestamp (yyyy.M.dHHmm)
calver() {
    local y m d hm
    y="$(date +%Y)"
    m="$(date +%m)"
    d="$(date +%d)"
    hm="$(date +%H%M)"
    printf '%s.%s.%s%s\n' "$y" "${m#0}" "${d#0}" "$hm"
}

# new_credential — interactive credential prompt
# Result stored in __CREDENTIAL_USER and __CREDENTIAL_PASS
new_credential() {
    printf '\nBash credential request\nEnter your credentials.\n\n'
    local user pass
    read -rp 'User: ' user
    read -rsp "Password for user ${user}: " pass
    printf '\n'
    export __CREDENTIAL_USER="$user"
    export __CREDENTIAL_PASS="$pass"
}

# Custom prompt — updates on every command via PROMPT_COMMAND
shopt -s checkwinsize
__dollarsign_prompt() {
    local git_branch
    git_branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null)"
    local path_display="${PWD/#$HOME/~}"
    local branch_str=''
    [[ -n "$git_branch" ]] && branch_str=" [${git_branch}]"
    local gt=''
    local shlvl_depth=$SHLVL
    shopt -q login_shell && (( shlvl_depth > 1 )) && (( shlvl_depth-- ))
    local i
    for ((i = 0; i < shlvl_depth; i++)); do gt+='>'; done
    PS1=$'\n'"[${COLUMNS}"$'\xc3\x97'"${LINES}] ${path_display}${branch_str}"$'\n'"bash${gt} "
}
PROMPT_COMMAND='__dollarsign_prompt'

# get_ip_address — cross-platform IP address retrieval
get_ip_address() {
    if [[ "$(uname -s)" == 'Darwin' ]]; then
        local i ip
        for i in $(ifconfig -l); do
            [[ "$i" == 'lo0' ]] && continue
            ip="$(ifconfig "$i" 2>/dev/null | awk '/inet [1-9]/{print $2; exit}')"
            [[ -n "$ip" ]] && printf '%s: %s\n' "$i" "$ip"
        done
    elif command -v ip &>/dev/null; then
        ip addr show | awk '
            /^[0-9]+: / {
                split($2, a, "@")
                iface = a[1]
                sub(/:$/, "", iface)
            }
            /inet [1-9]/ && iface != "lo" {
                addr = $2
                sub(/\/.*/, "", addr)
                print iface ": " addr
            }
        '
    else
        printf '[!] No IP address retrieval method found.\n' >&2
    fi
}

# gai — copy AI instruction URLs to clipboard
# flags: -p personal, -w powershell, -t pester (default: all)
gai() {
    local usePersonal=false
    local usePowerShell=false
    local usePester=false

    local OPTIND opt
    while getopts ':pwt' opt; do
        case "$opt" in
            p) usePersonal=true ;;
            w) usePowerShell=true ;;
            t) usePester=true ;;
            *) ;;
        esac
    done

    if [[ "$usePersonal" == false && "$usePowerShell" == false && "$usePester" == false ]]; then
        usePersonal=true
        usePowerShell=true
        usePester=true
    fi

    local instructions=''

    if [[ "$usePersonal" == true ]]; then
        instructions+='Please read and follow my personal instructions:
https://raw.githubusercontent.com/jakehildreth/jakehildreth/refs/heads/main/.github/copilot-instructions.md
'
    fi

    if [[ "$usePowerShell" == true ]]; then
        instructions+='then read and follow PowerShell best practices:
https://raw.githubusercontent.com/github/awesome-copilot/refs/heads/main/instructions/powershell.instructions.md
'
    fi

    if [[ "$usePester" == true ]]; then
        instructions+='then read and follow Pester testing best practices:
https://raw.githubusercontent.com/github/awesome-copilot/refs/heads/main/instructions/powershell-pester-5.instructions.md'
    fi

    if [[ "$(uname -s)" == 'Darwin' ]]; then
        printf '%s' "$instructions" | pbcopy
    elif command -v xclip &>/dev/null; then
        printf '%s' "$instructions" | xclip -selection clipboard
    elif command -v xsel &>/dev/null; then
        printf '%s' "$instructions" | xsel --clipboard --input
    else
        printf '[!] No clipboard tool found. Copy the following manually:\n\n%s\n' "$instructions"
    fi
}

# dcc — copy conventional commit workflow prompt to clipboard
dcc() {
    local prompt='Compare the current state of this project against its most recent commit.
Using the diff, draft a conventional commit following my standards, and present it to me for approval.
If I approve the commit message, commit the changes & push them.
If the current branch is not main, ask me if I want to do a PR.
If I say yes, draft a pull request title and description, then return the title and description as separate copy-pastable blocks.
If I say no, tell me you'\''re ready for the next task. In a robot style.'
    if [[ "$(uname -s)" == 'Darwin' ]]; then
        printf '%s' "$prompt" | pbcopy
    elif command -v xclip &>/dev/null; then
        printf '%s' "$prompt" | xclip -selection clipboard
    elif command -v xsel &>/dev/null; then
        printf '%s' "$prompt" | xsel --clipboard --input
    else
        printf '[!] No clipboard tool found. Copy the following manually:\n\n%s\n' "$prompt"
    fi
}
